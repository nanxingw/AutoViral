{
  "name": "@nanxingw/autocode-cli",
  "version": "0.2.0",
  "description": "AutoCode — Self-evolving intelligence for Claude Code: skills, memory, and autonomous tasks",
  "type": "module",
  "bin": {
    "autocode": "dist/index.js",
    "autoviral": "dist/index.js"
  },
  "files": [
    "dist/",
    "skills/",
    "web/dist/"
  ],
  "scripts": {
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "tsc",
    "build:frontend": "vite build",
    "dev": "tsc --watch",
    "dev:frontend": "vite dev",
    "postinstall": "node dist/postinstall.js",
    "test": "vitest run",
    "test:web": "vitest --config web/vitest.config.ts run",
    "test:web:watch": "vitest --config web/vitest.config.ts",
    "test:server": "vitest run --config vitest.server.config.ts",
    "test:server:watch": "vitest --config vitest.server.config.ts",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui"
  },
  "keywords": [
    "claude-code",
    "autocode",
    "autoviral",
    "ai",
    "agent",
    "automation",
    "claude"
  ],
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^7.0.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@hono/node-server": "^1.13.0",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-slider": "^1.2.3",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@remotion/bundler": "^4.0.452",
    "@remotion/cli": "^4.0.452",
    "@remotion/player": "^4.0.452",
    "@remotion/renderer": "^4.0.452",
    "@tanstack/react-query": "^5.62.0",
    "@types/dompurify": "^3.0.5",
    "clsx": "^2.1.1",
    "commander": "^12.0.0",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.3",
    "dotenv": "^16.4.0",
    "highlight.js": "^11.11.1",
    "hono": "^4.0.0",
    "immer": "^10.1.1",
    "js-yaml": "^4.1.0",
    "konva": "^9.3.22",
    "marked": "^17.0.4",
    "node-cron": "^3.0.0",
    "playwright": "^1.58.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-konva": "^18.2.14",
    "react-router-dom": "^6.28.0",
    "remotion": "^4.0.452",
    "wavesurfer.js": "^7.12.6",
    "ws": "^8.0.0",
    "zod": "^3.23.8",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.0",
    "@types/react": "^18.3.13",
    "@types/react-dom": "^18.3.1",
    "@types/ws": "^8.5.0",
    "@vitejs/plugin-react": "^4.3.4",
    "happy-dom": "^15.11.7",
    "msw": "^2.6.8",
    "typescript": "^5.9.3",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nanxingw/autocode.git"
  },
  "publishConfig": {
    "access": "public"
  }
}
